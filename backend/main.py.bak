def convert_bbox_to_yolo(image_width, image_height, bbox):
    """COCO bbox를 YOLO 형식으로 변환"""
    x, y, w, h = bbox
    x_center = (x + w / 2) / image_width
    y_center = (y + h / 2) / image_height
    w = w / image_width
    h = h / image_height
    return x_center, y_center, w, h

def process_coco_annotations_to_yolo(annotation_path, output_labels_dir, images_dir):
    """COCO annotation을 YOLO 형식으로 변환"""
    try:
        from pycocotools.coco import COCO
        
        coco = COCO(annotation_path)
        nc = 10  # 사용자 정의 클래스 10개로 제한
        
        processed_count = 0
        for img_id in coco.getImgIds():
            img_info = coco.loadImgs([img_id])[0]
            img_filename = img_info['file_name']
            img_path = os.path.join(images_dir, img_filename)
            
            if not os.path.exists(img_path):
                continue

            img_width, img_height = img_info['width'], img_info['height']
            annotations = coco.loadAnns(coco.getAnnIds(imgIds=[img_id]))
            
            label_file_path = os.path.join(output_labels_dir, f"{img_filename.split('.')[0]}.txt")
            with open(label_file_path, 'w') as label_file:
                seen_labels = set()
                for ann in annotations:
                    if 'bbox' in ann and ann.get('area', 0) > 0:
                        bbox = convert_bbox_to_yolo(img_width, img_height, ann['bbox'])
                        class_id = ann['category_id'] - 1  # COCO uses 1-based indexing
                        
                        if class_id >= nc or class_id < 0:
                            continue
                            
                        label_str = f"{class_id} {' '.join(map(str, bbox))}\n"
                        if label_str not in seen_labels:
                            label_file.write(label_str)
                            seen_labels.add(label_str)
            
            processed_count += 1
            
        return processed_count
        
    except Exception as e:
        logging.error(f"COCO annotation 변환 중 오류: {e}")
        raise

def create_yolo_dataset_structure(annotation_files, job_id):
    """다중 COCO 파일을 사용하여 YOLO 학습을 위한 데이터셋 구조 생성"""
    try:
        dataset_dir = f"training_datasets/{job_id}"
        os.makedirs(dataset_dir, exist_ok=True)
        os.makedirs(f"{dataset_dir}/images/train", exist_ok=True)
        os.makedirs(f"{dataset_dir}/images/val", exist_ok=True)
        os.makedirs(f"{dataset_dir}/labels/train", exist_ok=True)
        os.makedirs(f"{dataset_dir}/labels/val", exist_ok=True)

        total_processed_count = 0
        used_images = set()  # JSON에서 사용된 이미지 추적

        # 각 annotation 파일 처리
        for annotation_file in annotation_files:
            annotation_path = os.path.join("annotations", annotation_file)
            if not os.path.exists(annotation_path):
                raise FileNotFoundError(f"Annotation 파일을 찾을 수 없습니다: {annotation_path}")

            # COCO 파일에서 사용된 이미지 목록 추출
            with open(annotation_path, 'r', encoding='utf-8') as f:
                coco_data = json.load(f)

            for img_info in coco_data.get('images', []):
                img_filename = img_info.get('file_name')
                if img_filename:
                    used_images.add(img_filename)

            # COCO 데이터를 YOLO 형식으로 변환
            processed_count = process_coco_annotations_to_yolo(
                annotation_path,
                f"{dataset_dir}/labels/train",
                "images"
            )

            total_processed_count += processed_count
            logging.info(f"{annotation_file} 처리 완료: {processed_count}개 이미지")

        # JSON에서 명시된 이미지만 심볼릭 링크 생성
        linked_count = 0
        for img_filename in used_images:
            if img_filename.lower().endswith(('.jpg', '.jpeg', '.png')):
                img_path = os.path.abspath(os.path.join("images", img_filename))
                if os.path.exists(img_path):  # 실제 파일이 존재하는지 확인
                    symlink_path = os.path.join(dataset_dir, "images/train", img_filename)
                    if not os.path.exists(symlink_path):
                        os.symlink(img_path, symlink_path)
                        linked_count += 1
                else:
                    logging.warning(f"JSON에 명시된 이미지 파일을 찾을 수 없음: {img_filename}")

        logging.info(f"총 {linked_count}개의 이미지 파일이 학습 데이터셋에 링크됨 (JSON에서 명시된 이미지만)")
        
        # data.yaml 파일 생성 (10개 클래스로 제한)
        custom_classes = [
            'button_1', 'button_2', 'button_3', 'button_4', 'button_5',
            'button_6', 'button_7', 'button_8', 'button_9', 'button_10'
        ]
        
        data_yaml = {
            'train': os.path.abspath(f"{dataset_dir}/images/train"),
            'val': os.path.abspath(f"{dataset_dir}/images/train"),  # 검증용으로 같은 데이터 사용
            'nc': len(custom_classes),
            'names': {i: name for i, name in enumerate(custom_classes)}
        }
        
        yaml_path = f"{dataset_dir}/data.yaml"
        with open(yaml_path, 'w') as f:
            yaml.dump(data_yaml, f, default_flow_style=False)
        
        return dataset_dir, yaml_path, total_processed_count
        
    except Exception as e:
        logging.error(f"데이터셋 구조 생성 중 오류: {e}")
        raise

def load_trained_model(model_id):
    """학습된 모델 로드"""
    if model_id in loaded_models:
        return loaded_models[model_id]

    # trained_models에서 찾기
    model_path = Path(f"trained_models/model_{model_id}.pt")
    if model_path.exists():
        try:
            model = YOLO(str(model_path))
            loaded_models[model_id] = model
            logging.info(f"모델 로드 성공: {model_id}")
            return model
        except Exception as e:
            logging.error(f"모델 로드 실패 {model_id}: {e}")
            raise HTTPException(status_code=500, detail=f"모델 로드 실패: {str(e)}")

    # training_datasets에서 찾기
    parts = model_id.split('_')
    if len(parts) >= 2:
        dataset_id = '_'.join(parts[:-1])
        weight_type = parts[-1]
        weight_path = Path(f"training_datasets/{dataset_id}/runs/train/weights/{weight_type}.pt")

        if weight_path.exists():
            try:
                model = YOLO(str(weight_path))
                loaded_models[model_id] = model
                logging.info(f"모델 로드 성공: {model_id}")
                return model
            except Exception as e:
                logging.error(f"모델 로드 실패 {model_id}: {e}")
                raise HTTPException(status_code=500, detail=f"모델 로드 실패: {str(e)}")

    raise HTTPException(status_code=404, detail=f"모델 '{model_id}'를 찾을 수 없습니다.")

def run_model_inference(model, image_path, confidence=0.25):
    """모델로 추론 수행"""
    try:
        results = model(image_path, conf=confidence, verbose=False)
        return results[0]  # 첫 번째 결과 반환
    except Exception as e:
        logging.error(f"추론 실패: {e}")
        raise HTTPException(status_code=500, detail=f"추론 실패: {str(e)}")

def convert_yolo_to_coco_format(results, image_path, model_id):
    """추론 결과를 COCO 형식으로 변환"""
    from PIL import Image
    import uuid

    # 이미지 정보 가져오기
    img = Image.open(image_path)
    W, H = img.size

    # COCO 형식 데이터 구조
    coco_data = {
        "image": {
            "width": W,
            "height": H,
            "url": str(image_path),
            "filename": Path(image_path).name
        },
        "polygons": [],
        "metadata": {
            "model_id": model_id,
            "inference_id": uuid.uuid4().hex[:10],
            "created_at": datetime.now().isoformat(),
            "confidence_threshold": results.conf.tolist() if hasattr(results, 'conf') else []
        }
    }

    # 검출 결과 변환
    if results.boxes is not None and len(results.boxes) > 0:
        boxes = results.boxes.xyxy.cpu().numpy()  # x1,y1,x2,y2 형식
        confidences = results.boxes.conf.cpu().numpy()
        class_ids = results.boxes.cls.cpu().numpy().astype(int)

        # 클래스 라벨 매핑
        class_names = results.names  # {0: 'person', 1: 'car', ...}

        for i, (box, conf, cls_id) in enumerate(zip(boxes, confidences, class_ids)):
            x1, y1, x2, y2 = box

            # 박스를 폴리곤으로 변환 (사각형)
            polygon_coords = [
                float(x1), float(y1),  # 좌상
                float(x2), float(y1),  # 우상
                float(x2), float(y2),  # 우하
                float(x1), float(y2)   # 좌하
            ]

            polygon_data = {
                "label": class_names.get(cls_id, f"class_{cls_id}"),
                "points": polygon_coords,
                "confidence": float(conf),
                "detection_id": i
            }

            coco_data["polygons"].append(polygon_data)

    return coco_data

def train_yolo_model_background(job_id, dataset_dir, yaml_path, epochs=10, batch_size=16, img_size=640):
    """백그라운드에서 YOLO 모델 학습"""
    try:
        training_jobs[job_id]['status'] = 'training'
        training_jobs[job_id]['progress'] = 0

        # YOLOv8 모델 초기화
        model = YOLO('yolov8s.pt')

        # 학습 시작
        training_jobs[job_id]['message'] = '모델 학습 시작'
        results = model.train(
            data=yaml_path,
            epochs=epochs,
            batch=batch_size,
            imgsz=img_size,
            project=f"{dataset_dir}/runs",
            name="train",
            verbose=True,
            workers=0,  # 스레드 내 멀티프로세싱 충돌 방지
            amp=False  # 스레드 환경에서 AMP 충돌 방지
        )
        
        training_jobs[job_id]['progress'] = 80
        training_jobs[job_id]['message'] = '학습 완료, 검증 중'
        
        # 모델 검증
        metrics = model.val()
        
        # 모델 저장
        models_dir = "trained_models"
        os.makedirs(models_dir, exist_ok=True)
        
        model_name = f"model_{job_id}"
        model_path = f"{models_dir}/{model_name}.pt"
        torchscript_path = f"{models_dir}/{model_name}.torchscript"
        
        # 최고 성능 모델 복사
        best_model_path = f"{dataset_dir}/runs/train/weights/best.pt"
        if os.path.exists(best_model_path):
            shutil.copy2(best_model_path, model_path)
            
            # TorchScript 형식으로 변환
            model.export(format='torchscript', save_dir=models_dir)
            
        training_jobs[job_id]['status'] = 'completed'
        training_jobs[job_id]['progress'] = 100
        training_jobs[job_id]['message'] = '학습 완료'
        training_jobs[job_id]['model_path'] = model_path
        training_jobs[job_id]['torchscript_path'] = torchscript_path
        training_jobs[job_id]['metrics'] = {
            'map50': float(metrics.box.map50) if hasattr(metrics.box, 'map50') else 0,
            'map50_95': float(metrics.box.map) if hasattr(metrics.box, 'map') else 0,
            'precision': float(metrics.box.mp) if hasattr(metrics.box, 'mp') else 0,
            'recall': float(metrics.box.mr) if hasattr(metrics.box, 'mr') else 0
        }
        training_jobs[job_id]['completed_at'] = datetime.now().isoformat()

        logging.info(f"모델 학습 완료: {job_id}")
        
    except Exception as e:
        training_jobs[job_id]['status'] = 'failed'
        training_jobs[job_id]['message'] = f'학습 실패: {str(e)}'
        training_jobs[job_id]['error'] = str(e)
        logging.error(f"모델 학습 실패 {job_id}: {e}")

# --- YOLOv8 학습 관련 Pydantic 모델들 ---

class TrainingRequest(BaseModel):
    annotation_filenames: List[str]  # 다중 파일 지원
    epochs: int = 10
    batch_size: int = 16
    img_size: int = 640
    model_name: str = None


class PointPromptRequest(BaseModel):
    filename: str
    points: List[Tuple[int, int]]
    labels: List[int] = None  # 1 for foreground, 0 for background
    categories: List[str] = ["JOG", "MEMORY", "DOOR"]  # Gemini 분류 카테고리 (기본값)
    crop_padding_ratio: float = 0.15  # bbox crop 시 여유 비율 (기본 15%)

class PolygonToCOCORequest(BaseModel):
    image: dict  # {"width": int, "height": int, "url": str}
    polygons: List[dict]  # List of polygon objects
    metadata: dict = None  # Optional metadata

class GeminiSegmentationRequest(BaseModel):
    filename: str
    target: str
    model: str = "gemini-2.5-flash-preview-05-20"
    temperature: float = 0.5
    resize_width: int = 1024

class ModelInferenceRequest(BaseModel):
    model_id: str
    image_path: str
    confidence: float = 0.25
    save_labels: bool = True  # 자동으로 라벨 저장 여부

class HumanInLoopRequest(BaseModel):
    model_id: str
    image_paths: List[str]  # 추론할 이미지들
    confidence: float = 0.25
    output_dir: str = "human_in_loop_annotations"

@app.post("/api/generate-polygons-with-points")
async def generate_polygons_with_points(request: PointPromptRequest):
    """서버의 이미지 파일에서 특정 점들을 기반으로 SAM2를 사용하여 폴리곤을 생성합니다."""
    logging.info(f"점 기반 폴리곤 생성 요청 수신: {request.filename}, points: {request.points}")
    
    if predictor is None:
        logging.error("SAM2 predictor가 로드되지 않아 요청을 처리할 수 없습니다.")
        raise HTTPException(status_code=500, detail="SAM2 모델이 로드되지 않았습니다.")
    
    image_path = os.path.join("images", request.filename)
    if not os.path.isfile(image_path):
        logging.warning(f"이미지 파일을 찾을 수 없음: {image_path}")
        raise HTTPException(status_code=404, detail=f"이미지 '{request.filename}'를 찾을 수 없습니다.")

    try:
        logging.info(f"이미지 파일 로딩 시작: {image_path}")
        image = Image.open(image_path).convert("RGB")
        image_array = np.array(image)
        
        height, width, _ = image_array.shape
        
        # 점과 라벨 준비
        input_points = np.array(request.points)
        input_labels = np.array(request.labels if request.labels else [1] * len(request.points))
        
        if len(input_points) != len(input_labels):
            raise HTTPException(status_code=400, detail="점의 개수와 라벨의 개수가 일치하지 않습니다.")
        
        logging.info(f"이미지 크기: {width}x{height}. SAM2 점 기반 마스크 생성 시작...")
        
        # 이미지를 predictor에 설정
        predictor.set_image(image_array)
        
        # 점 기반 예측 수행
        masks, scores, logits = predictor.predict(
            point_coords=input_points,
            point_labels=input_labels,
            multimask_output=True
        )
        
        logging.info(f"SAM2 점 기반 마스크 생성 완료. {len(masks)}개의 마스크 생성.")

        # 마스크를 기존 형식으로 변환 (품질 0.9 이상만 필터링)
        formatted_masks = []
        mask_id = 0
        for i, (mask, score) in enumerate(zip(masks, scores)):
            # 품질 임계값 필터링 (IoU 0.9 이상만 포함)
            if score < 0.9:
                continue

            # 마스크에서 바운딩 박스 계산
            y_indices, x_indices = np.where(mask)
            if len(x_indices) > 0 and len(y_indices) > 0:
                x_min, x_max = x_indices.min(), x_indices.max()
                y_min, y_max = y_indices.min(), y_indices.max()
                bbox = [int(x_min), int(y_min), int(x_max - x_min), int(y_max - y_min)]
                area = int(mask.sum())

                polygons = mask_to_polygon(mask)

                mask_data = {
                    "id": mask_id,
                    "area": area,
                    "bbox": bbox,
                    "predicted_iou": float(score),
                    "stability_score": float(score),
                    "polygons": polygons
                }

                # Gemini classification 수행 (항상 활성화)
                try:
                    # bbox에 padding 적용하여 crop
                    x, y, w, h = bbox
                    padding_ratio = request.crop_padding_ratio
                    pad_w = int(w * padding_ratio)
                    pad_h = int(h * padding_ratio)

                    crop_x1 = max(0, x - pad_w)
                    crop_y1 = max(0, y - pad_h)
                    crop_x2 = min(width, x + w + pad_w)
                    crop_y2 = min(height, y + h + pad_h)

                    # crop된 이미지 추출
                    cropped_img = image_array[crop_y1:crop_y2, crop_x1:crop_x2]

                    if cropped_img.size > 0:
                        # Gemini 분류 수행
                        classification_result = classify_cropped_object(
                            cropped_img,
                            request.categories,
                            api_key=API_KEY
                        )

                        # 분류 결과 추가
                        mask_data["gemini_class"] = classification_result.get("class")
                        mask_data["classification_confidence"] = classification_result.get("confidence", 0.0)

                        logging.info(f"Gemini classification 완료: {classification_result.get('class')} (confidence: {classification_result.get('confidence')})")
                    else:
                        logging.warning(f"마스크 {mask_id}: crop 이미지 크기가 0입니다.")

                except Exception as e:
                    logging.warning(f"마스크 {mask_id} Gemini classification 실패: {str(e)}")
                    # Gemini 분류 실패해도 SAM 결과는 반환

                formatted_masks.append(mask_data)
                mask_id += 1
        
        return JSONResponse(content={
            "filename": request.filename,
            "image_dimensions": {"width": width, "height": height},
            "input_points": request.points,
            "masks": formatted_masks,
            "total_count": len(formatted_masks)
        })
        
    except Exception as e:
        logging.error(f"'{request.filename}' 점 기반 폴리곤 생성 중 오류 발생: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"점 기반 폴리곤 생성 중 오류 발생: {str(e)}")

@app.post("/api/gemini-segmentation")
async def gemini_segmentation(request: GeminiSegmentationRequest):
    """Gemini-2.5-pro를 사용하여 이미지에서 객체를 감지하고 세그멘테이션을 수행합니다."""
    logging.info(f"Gemini segmentation 요청 수신: {request.filename}, target: {request.target}")

    # GOOGLE_API_KEY 환경 변수 확인
    # if not os.getenv("GOOGLE_API_KEY"):
    #     logging.error("GOOGLE_API_KEY 환경 변수가 설정되지 않았습니다.")
    #     raise HTTPException(status_code=500, detail="GOOGLE_API_KEY 환경 변수가 설정되지 않았습니다.")

    # 이미지 파일 경로 확인
    image_path = os.path.join("images", request.filename)
    if not os.path.isfile(image_path):
        logging.warning(f"이미지 파일을 찾을 수 없음: {image_path}")
        raise HTTPException(status_code=404, detail=f"이미지 '{request.filename}'를 찾을 수 없습니다.")

    try:
        logging.info(f"Gemini segmentation 시작: {image_path}")

        # gemini_segmentation.py의 run_segmentation 함수 호출
        result = run_segmentation(
            image_path=image_path,
            target=request.target,
            model=request.model,
            temperature=request.temperature,
            resize_width=request.resize_width,
            api_key=API_KEY
        )

        logging.info(f"Gemini segmentation 완료: {len(result['instances'])}개의 객체 감지")

        # 결과를 SAM2 스타일 응답 형식으로 변환
        masks = []
        for i, instance in enumerate(result['instances']):
            bbox = instance['box_2d']  # [x1, y1, x2, y2]
            # bbox를 [x, y, width, height] 형식으로 변환
            bbox_xywh = [bbox[0], bbox[1], bbox[2] - bbox[0], bbox[3] - bbox[1]]
            area = (bbox[2] - bbox[0]) * (bbox[3] - bbox[1])

            # 바운딩 박스를 폴리곤으로 변환
            polygon = [
                [bbox[0], bbox[1]],  # 좌상단
                [bbox[2], bbox[1]],  # 우상단
                [bbox[2], bbox[3]],  # 우하단
                [bbox[0], bbox[3]]   # 좌하단
            ]

            masks.append({
                "id": i,
                "area": area,
                "bbox": bbox_xywh,
                "predicted_iou": 0.9,  # Gemini의 경우 고정값 사용
                "stability_score": 0.9,
                "polygons": [polygon],
                "label": instance['label']
            })

        return JSONResponse(content={
            "filename": request.filename,
            "target": request.target,
            "model": request.model,
            "image_dimensions": result['image_size'],
            "masks": masks,
            "total_count": len(masks),
            "gemini_result": result
        })

    except Exception as e:
        logging.error(f"Gemini segmentation 중 오류 발생: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"Gemini segmentation 중 오류 발생: {str(e)}")


@app.get("/api/images")
async def get_image_list():
    """images 폴더 내의 jpeg 파일 목록을 반환합니다."""
    image_dir = "images"
    if not os.path.isdir(image_dir):
        return JSONResponse(content={"error": f"'{image_dir}' 폴더를 찾을 수 없습니다."}, status_code=404)
    try:
        files = os.listdir(image_dir)
        image_files = sorted([f for f in files if f.lower().endswith(('.jpeg', '.jpg', '.png'))])
        return JSONResponse(content=image_files)
    except Exception as e:
        return JSONResponse(content={"error": str(e)}, status_code=500)

@app.get("/images/{filename}")
async def get_image_file(filename: str):
    """images 폴더 내의 이미지 파일을 반환합니다."""
    image_path = os.path.join("images", filename)
    if not os.path.isfile(image_path):
        return Response(content=f"이미지 '{filename}'를 찾을 수 없습니다.", status_code=404)
    return FileResponse(image_path)

@app.post("/api/upload-image")
async def upload_image(file: UploadFile = File(...)):
    """이미지를 업로드하고 images 폴더에 저장합니다."""
    logging.info(f"이미지 업로드 요청 수신: {file.filename}")
    
    if not file.content_type.startswith("image/"):
        raise HTTPException(status_code=400, detail="이미지 파일만 업로드 가능합니다.")
    
    # images 폴더가 없으면 생성
    image_dir = "images"
    if not os.path.exists(image_dir):
        os.makedirs(image_dir)
    
    try:
        # 원본 파일명 그대로 사용
        new_filename = file.filename
        
        image_path = os.path.join(image_dir, new_filename)
        
        # 파일 저장
        image_data = await file.read()
        with open(image_path, "wb") as f:
            f.write(image_data)
        
        logging.info(f"이미지가 성공적으로 저장됨: {image_path}")
        
        return JSONResponse(content={
            "message": "이미지가 성공적으로 업로드되었습니다.",
            "original_filename": file.filename,
            "saved_filename": new_filename,
            "file_path": image_path
        })
    except Exception as e:
        logging.error(f"이미지 업로드 중 오류 발생: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"이미지 업로드 중 오류 발생: {str(e)}")


@app.get("/api/generate-polygons/{filename}")
async def generate_polygons_from_file(filename: str):
    """서버의 이미지 파일에서 SAM2를 사용하여 폴리곤을 생성하고 JSON으로 반환합니다."""
    logging.info(f"서버 파일로부터 폴리곤 생성 요청 수신: {filename}")
    if mask_generator is None:
        logging.error("SAM2 모델이 로드되지 않아 요청을 처리할 수 없습니다.")
        raise HTTPException(status_code=500, detail="SAM2 모델이 로드되지 않았습니다.")
    
    image_path = os.path.join("images", filename)
    if not os.path.isfile(image_path):
        logging.warning(f"이미지 파일을 찾을 수 없음: {image_path}")
        raise HTTPException(status_code=404, detail=f"이미지 '{filename}'를 찾을 수 없습니다.")

    try:
        logging.info(f"이미지 파일 로딩 시작: {image_path}")
        image = Image.open(image_path).convert("RGB")
        image_array = np.array(image)
        
        # --- 이미지 크기 정보 추출 ---
        height, width, _ = image_array.shape
        
        logging.info(f"이미지 크기: {width}x{height}. SAM2 마스크 생성 시작...")
        masks = mask_generator.generate(image_array)
        logging.info(f"SAM2 마스크 생성 완료. {len(masks)}개의 마스크 감지.")
        
        # 마스크 데이터를 JSON 형식으로 변환
        json_result = process_and_format_masks(masks)
        
        return JSONResponse(content={
            "filename": filename,
            # --- 응답에 이미지 크기 추가 ---
            "image_dimensions": {"width": width, "height": height},
            "masks": json_result,
            "total_count": len(json_result)
        })
    except Exception as e:
        logging.error(f"'{filename}' 폴리곤 생성 중 오류 발생: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"폴리곤 생성 중 오류 발생: {str(e)}")

@app.post("/api/convert-to-coco")
async def convert_polygons_to_coco(request: PolygonToCOCORequest):
    """폴리곤 데이터를 COCO 형식으로 변환하고 서버에 저장합니다."""
    logging.info("폴리곤을 COCO 형식으로 변환 및 저장 요청 수신")

    # 입력 데이터 출력
    print("=" * 80)
    print("🔍 COCO 변환 입력 데이터:")
    print(f"📷 이미지 정보: {request.image}")
    print(f"📝 폴리곤 개수: {len(request.polygons)}")
    print(f"🏷️  메타데이터: {request.metadata}")

    print("\n📋 폴리곤 상세 정보:")
    for i, polygon in enumerate(request.polygons):
        print(f"  [{i+1}] ID: {polygon.get('id', 'N/A')}")
        print(f"      Label: {polygon.get('label', 'N/A')}")
        print(f"      BBox: {polygon.get('bbox', 'N/A')}")
        print(f"      Area: {polygon.get('area', 'N/A')}")
        print(f"      IoU: {polygon.get('predicted_iou', 'N/A')}")
        print(f"      Stability: {polygon.get('stability_score', 'N/A')}")
        if 'segmentation' in polygon:
            seg_len = len(polygon['segmentation']) if polygon['segmentation'] else 0
            print(f"      Segmentation Points: {seg_len}")
        print()
    print("=" * 80)
    
    try:
        # annotations 폴더가 없으면 생성
        annotation_dir = "annotations"
        if not os.path.exists(annotation_dir):
            os.makedirs(annotation_dir)
        
        # 현재 시간을 ISO 형식으로 생성
        from datetime import datetime
        import json
        current_time = datetime.now().isoformat()
        
        # 파일명 생성 (이미지 파일명에서 확장자 제거 후 _coco.json 추가)
        image_filename = request.image["url"].split("/")[-1]
        base_filename = os.path.splitext(image_filename)[0]
        coco_filename = f"{base_filename}_coco.json"
        coco_file_path = os.path.join(annotation_dir, coco_filename)
        
        # 폴리곤에서 고유 라벨 추출
        unique_labels = set()
        unlabeled_count = 0
        for polygon_data in request.polygons:
            # 라벨이 없거나 비어있으면 기본값 사용
            label = polygon_data.get("label")
            if not label or label.strip() == "":
                unlabeled_count += 1
                label = f"unlabeled_object_{unlabeled_count}"  # 더 명확한 기본 라벨
            unique_labels.add(label)

        # 라벨을 정렬하여 일관된 순서 보장
        sorted_labels = sorted(unique_labels)

        # 동적 카테고리 생성
        categories = []
        label_to_id = {}
        for i, label in enumerate(sorted_labels, 1):
            categories.append({
                "id": i,
                "name": label,
                "supercategory": "thing"
            })
            label_to_id[label] = i

        # 생성된 카테고리 출력
        print("\n🏷️  생성된 카테고리:")
        for category in categories:
            print(f"  ID {category['id']}: {category['name']}")
        print(f"📊 카테고리 매핑: {label_to_id}")

        # COCO 형식 구조 생성
        coco_data = {
            "info": {
                "description": "SAM2 Generated Annotations",
                "version": "1.0",
                "year": datetime.now().year,
                "contributor": "Grounded-SAM-2",
                "date_created": current_time
            },
            "licenses": [
                {
                    "id": 1,
                    "name": "Unknown",
                    "url": ""
                }
            ],
            "images": [
                {
                    "id": 1,
                    "width": request.image["width"],
                    "height": request.image["height"],
                    "file_name": image_filename,
                    "license": 1,
                    "date_captured": current_time
                }
            ],
            "categories": categories,
            "annotations": []
        }
        
        # 폴리곤을 COCO annotation으로 변환
        for polygon_data in request.polygons:
            # segmentation 데이터를 COCO 형식으로 변환 (flat list)
            segmentation = []
            if "segmentation" in polygon_data and polygon_data["segmentation"]:
                # [[x1,y1], [x2,y2], ...] -> [x1,y1,x2,y2,...]
                flat_coords = []
                for point in polygon_data["segmentation"]:
                    flat_coords.extend([float(point[0]), float(point[1])])
                segmentation = [flat_coords]
            
            # bbox 데이터 추출
            bbox = polygon_data.get("bbox", [0, 0, 0, 0])
            area = polygon_data.get("area", 0)
            
            # annotation ID 생성 (문자열 ID를 숫자로 변환)
            annotation_id = polygon_data.get("id", 0)
            if isinstance(annotation_id, str):
                # "polygon-0" 형식에서 숫자 추출
                import re
                match = re.search(r'\d+', annotation_id)
                annotation_id = int(match.group()) if match else len(coco_data["annotations"]) + 1

            # 라벨에 따른 category_id 할당
            label = polygon_data.get("label")
            if not label or label.strip() == "":
                # 카운터를 다시 계산하여 일관성 유지
                unlabeled_objects = [p for p in request.polygons if not p.get("label") or p.get("label").strip() == ""]
                current_index = unlabeled_objects.index(polygon_data) + 1
                label = f"unlabeled_object_{current_index}"
            category_id = label_to_id.get(label, 1)  # 기본값은 1

            annotation = {
                "id": annotation_id,
                "image_id": 1,
                "category_id": category_id,
                "segmentation": segmentation,
                "bbox": [float(x) for x in bbox],  # [x, y, width, height]
                "area": float(area),
                "iscrowd": 0
            }
            
            # 추가 메타데이터가 있다면 포함
            if "predicted_iou" in polygon_data:
                annotation["predicted_iou"] = float(polygon_data["predicted_iou"])
            if "stability_score" in polygon_data:
                annotation["stability_score"] = float(polygon_data["stability_score"])
            
            coco_data["annotations"].append(annotation)
        
        # 파일로 저장
        with open(coco_file_path, "w", encoding="utf-8") as f:
            json.dump(coco_data, f, indent=2, ensure_ascii=False)
        
        logging.info(f"COCO 변환 및 저장 완료: {len(coco_data['annotations'])}개의 annotation 생성, 파일: {coco_file_path}")

        # 변환 결과 요약 출력
        print("\n✅ COCO 변환 완료:")
        print(f"💾 저장 파일: {coco_filename}")
        print(f"📊 생성된 annotation 수: {len(coco_data['annotations'])}")
        print(f"🏷️  카테고리 수: {len(coco_data['categories'])}")
        print(f"📝 파일 경로: {coco_file_path}")
        print("=" * 80)

        return JSONResponse(content={
            "message": "COCO 데이터가 성공적으로 변환되고 저장되었습니다.",
            "saved_filename": coco_filename,
            "file_path": coco_file_path,
            "annotations_count": len(coco_data["annotations"]),
            "coco_data": coco_data
        })
        
    except Exception as e:
        logging.error(f"COCO 변환 및 저장 중 오류 발생: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"COCO 변환 및 저장 중 오류 발생: {str(e)}")

@app.get("/api/annotations")
async def get_annotations_list():
    """저장된 COCO annotation 파일 목록을 반환합니다."""
    annotation_dir = "annotations"
    if not os.path.isdir(annotation_dir):
        return JSONResponse(content={"error": f"'{annotation_dir}' 폴더를 찾을 수 없습니다."}, status_code=404)
    try:
        files = os.listdir(annotation_dir)
        json_files = sorted([f for f in files if f.lower().endswith('.json')])
        
        # 간단한 파일 목록 반환
        file_info = []
        for filename in json_files:
            file_path = os.path.join(annotation_dir, filename)
            stat = os.stat(file_path)
            file_info.append({
                "filename": filename,
                "size": stat.st_size,
                "modified_time": stat.st_mtime
            })
        
        return JSONResponse(content={
            "files": file_info,
            "total_count": len(file_info)
        })
    except Exception as e:
        logging.error(f"annotation 파일 목록 조회 중 오류 발생: {str(e)}", exc_info=True)
        return JSONResponse(content={"error": str(e)}, status_code=500)

@app.get("/api/annotations/{filename}")
async def get_annotation_file(filename: str):
    """특정 COCO annotation 파일을 다운로드합니다."""
    annotation_dir = "annotations"
    file_path = os.path.join(annotation_dir, filename)
    
    if not os.path.isfile(file_path):
        logging.warning(f"annotation 파일을 찾을 수 없음: {file_path}")
        raise HTTPException(status_code=404, detail=f"annotation 파일 '{filename}'를 찾을 수 없습니다.")
    
    return FileResponse(
        file_path,
        media_type="application/json",
        filename=filename,
        headers={"Content-Disposition": f"attachment; filename={filename}"}
    )

@app.delete("/api/annotations/{filename}")
async def delete_annotation_file(filename: str):
    """특정 COCO annotation 파일을 삭제합니다."""
    annotation_dir = "annotations"
    file_path = os.path.join(annotation_dir, filename)

    if not os.path.isfile(file_path):
        logging.warning(f"annotation 파일을 찾을 수 없음: {file_path}")
        raise HTTPException(status_code=404, detail=f"annotation 파일 '{filename}'를 찾을 수 없습니다.")

    try:
        os.remove(file_path)
        logging.info(f"annotation 파일 삭제 완료: {filename}")
        return JSONResponse(content={
            "message": f"파일 '{filename}'가 삭제되었습니다.",
            "deleted_file": filename,
            "deleted_at": datetime.now().isoformat()
        })
    except Exception as e:
        logging.error(f"파일 삭제 중 오류: {e}")
        raise HTTPException(status_code=500, detail=f"파일 삭제 실패: {str(e)}")


# --- YOLOv8 학습 관련 API 엔드포인트들 ---

@app.post("/api/train-model")
async def start_model_training(request: TrainingRequest):
    """선택된 annotation 파일들로 YOLOv8 모델 학습을 시작합니다."""
    logging.info(f"모델 학습 시작 요청: annotation_files={request.annotation_filenames}, epochs={request.epochs}")

    try:
        # ultralytics 라이브러리 확인
        from ultralytics import YOLO
    except ImportError:
        raise HTTPException(status_code=500, detail="YOLOv8 학습을 위한 ultralytics 라이브러리가 설치되지 않았습니다.")

    # 파일 개수 검증
    if not request.annotation_filenames or len(request.annotation_filenames) == 0:
        raise HTTPException(status_code=400, detail="최소 1개 이상의 annotation 파일을 선택해야 합니다.")

    # 다중 annotation 파일 존재 및 유효성 확인
    total_images = 0
    total_annotations = 0
    validated_files = []

    for filename in request.annotation_filenames:
        annotation_path = os.path.join("annotations", filename)

        # 파일 존재 확인
        if not os.path.exists(annotation_path):
            raise HTTPException(status_code=404, detail=f"Annotation 파일 '{filename}'를 찾을 수 없습니다.")

        # COCO 파일 유효성 검증
        try:
            with open(annotation_path, 'r', encoding='utf-8') as f:
                coco_data = json.load(f)

            # 필수 필드 확인
            if 'images' not in coco_data or 'annotations' not in coco_data:
                raise HTTPException(status_code=400, detail=f"'{filename}'는 유효한 COCO 형식이 아닙니다.")

            images_count = len(coco_data.get('images', []))
            annotations_count = len(coco_data.get('annotations', []))

            if images_count == 0 or annotations_count == 0:
                raise HTTPException(status_code=400, detail=f"'{filename}'에는 학습 가능한 데이터가 없습니다.")

            total_images += images_count
            total_annotations += annotations_count
            validated_files.append({
                "filename": filename,
                "images_count": images_count,
                "annotations_count": annotations_count
            })

            logging.info(f"COCO 파일 검증 완료 - {filename}: {images_count}개 이미지, {annotations_count}개 annotation")

        except json.JSONDecodeError:
            raise HTTPException(status_code=400, detail=f"'{filename}'는 유효한 JSON 파일이 아닙니다.")
        except Exception as e:
            raise HTTPException(status_code=400, detail=f"COCO 파일 검증 실패 ({filename}): {str(e)}")

    logging.info(f"전체 검증 완료: {len(validated_files)}개 파일, 총 {total_images}개 이미지, {total_annotations}개 annotation")
    
    # 작업 ID 생성
    job_id = str(uuid.uuid4())[:8]
    
    try:
        # 데이터셋 구조 생성 (다중 파일 지원)
        dataset_dir, yaml_path, processed_count = create_yolo_dataset_structure(request.annotation_filenames, job_id)

        # 학습 작업 정보 초기화
        training_jobs[job_id] = {
            'status': 'preparing',
            'progress': 10,
            'message': f'데이터셋 준비 완료 ({processed_count}개 이미지)',
            'annotation_filenames': request.annotation_filenames,  # 다중 파일명 저장
            'epochs': request.epochs,
            'batch_size': request.batch_size,
            'img_size': request.img_size,
            'model_name': request.model_name or f"model_{job_id}",
            'created_at': datetime.now().isoformat(),
            'dataset_dir': dataset_dir,
            'yaml_path': yaml_path,
            'processed_count': processed_count
        }
        
        # 백그라운드에서 학습 시작
        thread = threading.Thread(
            target=train_yolo_model_background,
            args=(job_id, dataset_dir, yaml_path, request.epochs, request.batch_size, request.img_size)
        )
        thread.daemon = True
        thread.start()
        
        logging.info(f"모델 학습 시작됨: job_id={job_id}, 파일 수={len(request.annotation_filenames)}, 처리된 이미지 수={processed_count}")

        return JSONResponse(content={
            "message": "모델 학습이 시작되었습니다.",
            "job_id": job_id,
            "status": "preparing",
            "annotation_filenames": request.annotation_filenames,  # 다중 파일명 반환
            "files_count": len(request.annotation_filenames),      # 파일 개수
            "processed_images_count": processed_count,
            "training_parameters": {
                "epochs": request.epochs,
                "batch_size": request.batch_size,
                "img_size": request.img_size
            }
        })
        
    except Exception as e:
        logging.error(f"모델 학습 시작 중 오류: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"모델 학습 시작 중 오류 발생: {str(e)}")

@app.get("/api/training/status/{job_id}")
async def get_training_status(job_id: str):
    """특정 학습 작업의 상태를 조회합니다."""
    if job_id not in training_jobs:
        raise HTTPException(status_code=404, detail=f"학습 작업 '{job_id}'를 찾을 수 없습니다.")
    
    job_info = training_jobs[job_id]
    return JSONResponse(content={
        "job_id": job_id,
        "status": job_info['status'],
        "progress": job_info['progress'],
        "message": job_info['message'],
        "created_at": job_info['created_at'],
        "completed_at": job_info.get('completed_at'),
        "annotation_filenames": job_info['annotation_filenames'],
        "model_name": job_info['model_name'],
        "training_parameters": {
            "epochs": job_info['epochs'],
            "batch_size": job_info['batch_size'],
            "img_size": job_info['img_size']
        },
        "processed_images_count": job_info.get('processed_count', 0),
        "metrics": job_info.get('metrics'),
        "error": job_info.get('error')
    })

@app.get("/api/training/jobs")
async def list_training_jobs():
    """모든 학습 작업 목록을 조회합니다."""
    jobs_list = []
    for job_id, job_info in training_jobs.items():
        jobs_list.append({
            "job_id": job_id,
            "status": job_info['status'],
            "progress": job_info['progress'],
            "message": job_info['message'],
            "created_at": job_info['created_at'],
            "completed_at": job_info.get('completed_at'),
            "annotation_filenames": job_info['annotation_filenames'],
            "model_name": job_info['model_name'],
            "processed_images_count": job_info.get('processed_count', 0)
        })
    
    return JSONResponse(content={
        "jobs": sorted(jobs_list, key=lambda x: x['created_at'], reverse=True),
        "total_count": len(jobs_list)
    })

@app.delete("/api/training/jobs/{job_id}")
async def cancel_training_job(job_id: str):
    """학습 작업을 취소하거나 삭제합니다."""
    if job_id not in training_jobs:
        raise HTTPException(status_code=404, detail=f"학습 작업 '{job_id}'를 찾을 수 없습니다.")
    
    job_info = training_jobs[job_id]
    
    # 진행 중인 작업은 상태만 변경 (실제 중단은 어려움)
    if job_info['status'] in ['preparing', 'training']:
        training_jobs[job_id]['status'] = 'cancelled'
        training_jobs[job_id]['message'] = '사용자에 의해 취소됨'
        logging.info(f"학습 작업 취소 요청: {job_id}")
    
    # 작업 기록 삭제
    del training_jobs[job_id]
    
    return JSONResponse(content={
        "message": f"학습 작업 '{job_id}'가 삭제되었습니다.",
        "job_id": job_id
    })

@app.get("/api/models")
async def list_trained_models():
    """학습된 모델 목록을 조회합니다."""
    models_dir = "trained_models"
    if not os.path.exists(models_dir):
        return JSONResponse(content={"models": [], "total_count": 0})
    
    models_list = []
    
    # 완료된 학습 작업에서 모델 정보 가져오기
    for job_id, job_info in training_jobs.items():
        if job_info['status'] == 'completed' and 'model_path' in job_info:
            model_path = job_info['model_path']
            if os.path.exists(model_path):
                model_info = {
                    "model_id": job_id,
                    "model_name": job_info['model_name'],
                    "model_path": model_path,
                    "torchscript_path": job_info.get('torchscript_path'),
                    "created_at": job_info['completed_at'],
                    "annotation_filenames": job_info['annotation_filenames'],
                    "training_parameters": {
                        "epochs": job_info['epochs'],
                        "batch_size": job_info['batch_size'],
                        "img_size": job_info['img_size']
                    },
                    "metrics": job_info.get('metrics', {}),
                    "processed_images_count": job_info.get('processed_count', 0)
                }
                
                # 파일 크기 정보 추가
                try:
                    model_stat = os.stat(model_path)
                    model_info["file_size"] = model_stat.st_size
                    model_info["modified_time"] = model_stat.st_mtime
                except:
                    pass
                
                models_list.append(model_info)
    
    return JSONResponse(content={
        "models": sorted(models_list, key=lambda x: x.get('created_at', ''), reverse=True),
        "total_count": len(models_list)
    })

@app.get("/api/models/weights")
async def list_model_weights():
    """사용 가능한 모델 weight 목록을 조회합니다."""
    weights = []

    # trained_models 디렉토리에서 모델 파일 찾기
    models_dir = Path("trained_models")
    if models_dir.exists():
        for model_file in models_dir.glob("*.pt"):
            model_id = model_file.stem.replace("model_", "")

            # training_jobs에서 모델 정보 가져오기
            model_info = {
                "model_id": model_id,
                "filename": model_file.name,
                "filepath": str(model_file),
                "size_mb": round(model_file.stat().st_size / (1024 * 1024), 2),
                "created_at": datetime.fromtimestamp(model_file.stat().st_mtime).isoformat(),
                "status": "unknown",
                "metrics": {},
                "training_info": {}
            }

            # training_jobs에서 추가 정보 가져오기
            if model_id in training_jobs:
                job_info = training_jobs[model_id]
                model_info.update({
                    "status": job_info.get('status', 'unknown'),
                    "metrics": job_info.get('metrics', {}),
                    "training_info": {
                        "created_at": job_info.get('created_at', ''),
                        "completed_at": job_info.get('completed_at', ''),
                        "message": job_info.get('message', ''),
                        "progress": job_info.get('progress', 0),
                        "dataset_name": job_info.get('dataset_name', ''),
                        "annotation_files": job_info.get('annotation_files', []),
                        "epochs": job_info.get('epochs', 0),
                        "batch_size": job_info.get('batch_size', 0)
                    }
                })

            weights.append(model_info)

    # 또한 training_datasets에서 best.pt 파일들도 찾기
    datasets_dir = Path("training_datasets")
    if datasets_dir.exists():
        for dataset_dir in datasets_dir.iterdir():
            if dataset_dir.is_dir():
                best_weight = dataset_dir / "runs" / "train" / "weights" / "best.pt"
                last_weight = dataset_dir / "runs" / "train" / "weights" / "last.pt"

                for weight_file in [best_weight, last_weight]:
                    if weight_file.exists():
                        model_id = f"{dataset_dir.name}_{weight_file.stem}"

                        weight_info = {
                            "model_id": model_id,
                            "filename": f"{dataset_dir.name}_{weight_file.name}",
                            "filepath": str(weight_file),
                            "size_mb": round(weight_file.stat().st_size / (1024 * 1024), 2),
                            "created_at": datetime.fromtimestamp(weight_file.stat().st_mtime).isoformat(),
                            "status": "training_artifact",
                            "type": weight_file.stem,  # "best" or "last"
                            "dataset_id": dataset_dir.name,
                            "metrics": {},
                            "training_info": {}
                        }

                        # training_jobs에서 정보 가져오기
                        if dataset_dir.name in training_jobs:
                            job_info = training_jobs[dataset_dir.name]
                            weight_info["metrics"] = job_info.get('metrics', {})
                            weight_info["training_info"] = {
                                "created_at": job_info.get('created_at', ''),
                                "completed_at": job_info.get('completed_at', ''),
                                "message": job_info.get('message', ''),
                                "dataset_name": job_info.get('dataset_name', ''),
                                "annotation_files": job_info.get('annotation_files', []),
                                "epochs": job_info.get('epochs', 0),
                                "batch_size": job_info.get('batch_size', 0)
                            }

                        weights.append(weight_info)

    # 생성 시간순으로 정렬 (최신순)
    weights.sort(key=lambda x: x['created_at'], reverse=True)

    return {
        "total_models": len(weights),
        "models": weights
    }

@app.get("/api/models/{model_id}")
