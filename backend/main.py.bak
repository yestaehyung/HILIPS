def mask_to_polygon(mask):
    """부울 마스크를 폴리곤 좌표 리스트로 변환하는 함수"""
    mask_uint8 = (mask * 255).astype(np.uint8)
    contours, _ = cv2.findContours(mask_uint8, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    polygons = []
    for contour in contours:
        epsilon = 0.02 * cv2.arcLength(contour, True)
        approx = cv2.approxPolyDP(contour, epsilon, True)
        if len(approx) >= 3:
            polygon = [(int(point[0][0]), int(point[0][1])) for point in approx]
            polygons.append(polygon)
    return polygons

def process_and_format_masks(masks):
    """
    SAM2 마스크 리스트를 API 응답 형식에 맞는 JSON 데이터로 변환하는 헬퍼 함수
    """
    output_data = []
    for i, mask_data in enumerate(masks):
        # 'segmentation' 마스크를 폴리곤 좌표로 변환
        polygons = mask_to_polygon(mask_data['segmentation'])
        
        output_data.append({
            "id": i,
            "area": float(mask_data.get('area', 0)),
            "bbox": mask_data.get('bbox', []), # .tolist()가 필요 없음
            "predicted_iou": float(mask_data.get('predicted_iou', 0)),
            "stability_score": float(mask_data.get('stability_score', 0)),
            "polygons": polygons
        })
    return output_data

