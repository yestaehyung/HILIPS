@app.get("/api/models/weights/{model_id}")
async def get_model_weight_details(model_id: str):
    """특정 모델 weight의 상세 정보를 조회합니다."""
    # trained_models에서 찾기
    model_path = Path(f"trained_models/model_{model_id}.pt")
    if model_path.exists():
        # 기본 모델 정보
        model_info = {
            "model_id": model_id,
            "filename": model_path.name,
            "filepath": str(model_path),
            "size_mb": round(model_path.stat().st_size / (1024 * 1024), 2),
            "created_at": datetime.fromtimestamp(model_path.stat().st_mtime).isoformat(),
            "status": "unknown",
            "metrics": {},
            "training_info": {},
            "type": "trained_model"
        }

        # training_jobs에 정보가 있으면 업데이트
        if model_id in training_jobs:
            job_info = training_jobs[model_id]
            model_info.update({
                "status": job_info.get('status', 'unknown'),
                "metrics": job_info.get('metrics', {}),
                "training_info": job_info
            })

        return model_info

    # training_datasets에서 찾기
    parts = model_id.split('_')
    if len(parts) >= 2:
        dataset_id = '_'.join(parts[:-1])
        weight_type = parts[-1]

        weight_path = Path(f"training_datasets/{dataset_id}/runs/train/weights/{weight_type}.pt")
        if weight_path.exists():
            result = {
                "model_id": model_id,
                "filename": f"{dataset_id}_{weight_type}.pt",
                "filepath": str(weight_path),
                "size_mb": round(weight_path.stat().st_size / (1024 * 1024), 2),
                "created_at": datetime.fromtimestamp(weight_path.stat().st_mtime).isoformat(),
                "status": "training_artifact",
                "type": weight_type,
                "dataset_id": dataset_id,
                "metrics": {},
                "training_info": {}
            }

            if dataset_id in training_jobs:
                job_info = training_jobs[dataset_id]
                result["metrics"] = job_info.get('metrics', {})
                result["training_info"] = job_info

            return result

    raise HTTPException(status_code=404, detail=f"Model weight '{model_id}'를 찾을 수 없습니다.")

@app.post("/api/models/weights/compare")
async def compare_model_weights(model_ids: List[str]):
    """여러 모델 weight들을 비교합니다."""
    if len(model_ids) < 2:
        raise HTTPException(status_code=400, detail="비교하려면 최소 2개 이상의 모델이 필요합니다.")

    models = []
    for model_id in model_ids:
        try:
            model_details = await get_model_weight_details(model_id)
            models.append(model_details)
        except HTTPException:
            # 모델을 찾을 수 없는 경우 무시하고 계속
            continue

    if len(models) < 2:
        raise HTTPException(status_code=400, detail="비교 가능한 모델이 충분하지 않습니다.")

    # 메트릭 비교
    comparison = {
        "models": models,
        "comparison": {
            "best_map50": None,
            "best_map50_95": None,
            "best_precision": None,
            "best_recall": None,
            "model_sizes": [(m["model_id"], m["size_mb"]) for m in models],
            "creation_dates": [(m["model_id"], m["created_at"]) for m in models]
        }
    }

    # 최고 메트릭 찾기
    best_map50 = max(models, key=lambda x: x.get("metrics", {}).get("map50", 0), default=None)
    best_map50_95 = max(models, key=lambda x: x.get("metrics", {}).get("map50_95", 0), default=None)
    best_precision = max(models, key=lambda x: x.get("metrics", {}).get("precision", 0), default=None)
    best_recall = max(models, key=lambda x: x.get("metrics", {}).get("recall", 0), default=None)

    if best_map50:
        comparison["comparison"]["best_map50"] = {
            "model_id": best_map50["model_id"],
            "value": best_map50.get("metrics", {}).get("map50", 0)
        }

    if best_map50_95:
        comparison["comparison"]["best_map50_95"] = {
            "model_id": best_map50_95["model_id"],
            "value": best_map50_95.get("metrics", {}).get("map50_95", 0)
        }

    if best_precision:
        comparison["comparison"]["best_precision"] = {
            "model_id": best_precision["model_id"],
            "value": best_precision.get("metrics", {}).get("precision", 0)
        }

    if best_recall:
        comparison["comparison"]["best_recall"] = {
            "model_id": best_recall["model_id"],
            "value": best_recall.get("metrics", {}).get("recall", 0)
        }

    return comparison

@app.post("/api/models/{model_id}/inference")
async def model_inference(model_id: str, request: ModelInferenceRequest):
    """선택한 모델로 이미지 추론 수행"""
    logging.info(f"모델 추론 요청: {model_id}, 이미지: {request.image_path}")

    # 이미지 파일 확인
    image_path = Path(request.image_path)
    if not image_path.exists():
        # images/ 디렉토리에서 찾기
        image_path = Path("images") / request.image_path
        if not image_path.exists():
            raise HTTPException(status_code=404, detail=f"이미지 파일을 찾을 수 없습니다: {request.image_path}")

    # 모델 로드
    model = load_trained_model(model_id)

    # 추론 수행
    results = run_model_inference(model, str(image_path), request.confidence)

    # COCO 형식으로 변환
    coco_data = convert_yolo_to_coco_format(results, str(image_path), model_id)

    # 라벨 자동 저장 옵션
    if request.save_labels:
        output_dir = Path("annotations")
        output_dir.mkdir(exist_ok=True)

        # 파일명 생성
        image_name = image_path.stem
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        output_filename = f"{image_name}_inference_{model_id}_{timestamp}.json"
        output_path = output_dir / output_filename

        # JSON 저장
        with open(output_path, 'w', encoding='utf-8') as f:
            json.dump(coco_data, f, ensure_ascii=False, indent=2)

        coco_data["metadata"]["saved_to"] = str(output_path)
        logging.info(f"추론 결과 저장: {output_path}")

    return {
        "success": True,
        "model_id": model_id,
        "image_path": str(image_path),
        "detections_count": len(coco_data["polygons"]),
        "inference_data": coco_data
    }

@app.post("/api/human-in-loop/start")
async def start_human_in_loop(request: HumanInLoopRequest):
    """여러 이미지에 대해 Human-in-the-Loop 세션 시작"""
    session_id = uuid.uuid4().hex[:10]
    logging.info(f"Human-in-Loop 세션 시작: {session_id}, 모델: {request.model_id}")

    # 모델 로드
    model = load_trained_model(request.model_id)

    # 출력 디렉토리 생성
    output_dir = Path(request.output_dir) / session_id
    output_dir.mkdir(parents=True, exist_ok=True)

    # 세션 정보 초기화
    session_info = {
        "session_id": session_id,
        "model_id": request.model_id,
        "created_at": datetime.now().isoformat(),
        "status": "processing",
        "total_images": len(request.image_paths),
        "processed_images": 0,
        "output_dir": str(output_dir),
        "confidence": request.confidence,
        "images": [],
        "errors": []
    }

    hil_sessions[session_id] = session_info

    # 백그라운드에서 처리
    def process_images():
        try:
            for i, image_path in enumerate(request.image_paths):
                try:
                    # 이미지 경로 확인
                    img_path = Path(image_path)
                    if not img_path.exists():
                        img_path = Path("images") / image_path
                        if not img_path.exists():
                            session_info["errors"].append(f"이미지 없음: {image_path}")
                            continue

                    # 추론 수행
                    results = run_model_inference(model, str(img_path), request.confidence)
                    coco_data = convert_yolo_to_coco_format(results, str(img_path), request.model_id)

                    # 결과 저장
                    image_name = img_path.stem
                    output_filename = f"{image_name}_inference.json"
                    output_path = output_dir / output_filename

                    with open(output_path, 'w', encoding='utf-8') as f:
                        json.dump(coco_data, f, ensure_ascii=False, indent=2)

                    # 세션 정보 업데이트
                    image_info = {
                        "original_path": str(img_path),
                        "inference_file": str(output_path),
                        "detections_count": len(coco_data["polygons"]),
                        "status": "completed",
                        "reviewed": False
                    }
                    session_info["images"].append(image_info)
                    session_info["processed_images"] += 1

                    logging.info(f"처리 완료: {image_path} ({i+1}/{len(request.image_paths)})")

                except Exception as e:
                    error_msg = f"이미지 처리 오류 {image_path}: {str(e)}"
                    session_info["errors"].append(error_msg)
                    logging.error(error_msg)

            # 세션 완료
            session_info["status"] = "completed"
            session_info["completed_at"] = datetime.now().isoformat()
            logging.info(f"Human-in-Loop 세션 완료: {session_id}")

        except Exception as e:
            session_info["status"] = "failed"
            session_info["error"] = str(e)
            logging.error(f"Human-in-Loop 세션 실패: {session_id}, {e}")

    # 백그라운드 실행
    thread = threading.Thread(target=process_images)
    thread.start()

    return {
        "success": True,
        "session_id": session_id,
        "status": "processing",
        "total_images": len(request.image_paths),
        "output_dir": str(output_dir)
    }

@app.get("/api/human-in-loop/{session_id}/status")
async def get_hil_session_status(session_id: str):
    """세션 상태 조회"""
    if session_id not in hil_sessions:
        raise HTTPException(status_code=404, detail=f"세션 '{session_id}'를 찾을 수 없습니다.")

    return hil_sessions[session_id]

@app.get("/api/human-in-loop/{session_id}/images")
async def get_hil_session_images(session_id: str):
    """세션의 이미지 목록 및 검토 상태 조회"""
    if session_id not in hil_sessions:
        raise HTTPException(status_code=404, detail=f"세션 '{session_id}'를 찾을 수 없습니다.")

    session_info = hil_sessions[session_id]

    # 이미지별 상세 정보 로드
    detailed_images = []
    for img_info in session_info["images"]:
        try:
            # JSON 파일 로드
            with open(img_info["inference_file"], 'r', encoding='utf-8') as f:
                inference_data = json.load(f)

            detailed_info = {
                "original_path": img_info["original_path"],
                "inference_file": img_info["inference_file"],
                "detections_count": img_info["detections_count"],
                "status": img_info["status"],
                "reviewed": img_info["reviewed"],
                "inference_data": inference_data
            }
            detailed_images.append(detailed_info)
        except Exception as e:
            logging.error(f"이미지 데이터 로드 오류: {e}")
            continue

    return {
        "session_id": session_id,
        "total_images": len(detailed_images),
        "reviewed_count": sum(1 for img in detailed_images if img["reviewed"]),
        "images": detailed_images
    }

@app.put("/api/human-in-loop/{session_id}/labels/{image_index}")
async def update_hil_labels(session_id: str, image_index: int, updated_data: dict):
    """사용자가 수정한 라벨 저장"""
    if session_id not in hil_sessions:
        raise HTTPException(status_code=404, detail=f"세션 '{session_id}'를 찾을 수 없습니다.")

    session_info = hil_sessions[session_id]

    if image_index >= len(session_info["images"]):
        raise HTTPException(status_code=404, detail=f"이미지 인덱스 '{image_index}'를 찾을 수 없습니다.")

    image_info = session_info["images"][image_index]
    inference_file = Path(image_info["inference_file"])

    try:
        # 기존 데이터 로드
        with open(inference_file, 'r', encoding='utf-8') as f:
            original_data = json.load(f)

        # 수정 이력 추가
        updated_data["metadata"]["modified_at"] = datetime.now().isoformat()
        updated_data["metadata"]["original_inference_id"] = original_data["metadata"].get("inference_id")
        updated_data["metadata"]["human_reviewed"] = True

        # 수정된 데이터 저장
        with open(inference_file, 'w', encoding='utf-8') as f:
            json.dump(updated_data, f, ensure_ascii=False, indent=2)

        # 백업 파일도 생성 (원본 보존)
        backup_file = inference_file.with_suffix('.original.json')
        if not backup_file.exists():
            with open(backup_file, 'w', encoding='utf-8') as f:
                json.dump(original_data, f, ensure_ascii=False, indent=2)

        # 세션 정보 업데이트
        session_info["images"][image_index]["reviewed"] = True
        session_info["images"][image_index]["detections_count"] = len(updated_data.get("polygons", []))

        logging.info(f"라벨 업데이트 완료: {session_id}, 이미지 {image_index}")

        return {
            "success": True,
            "session_id": session_id,
            "image_index": image_index,
            "updated_detections": len(updated_data.get("polygons", [])),
            "backup_created": str(backup_file)
        }

    except Exception as e:
        logging.error(f"라벨 업데이트 오류: {e}")
        raise HTTPException(status_code=500, detail=f"라벨 업데이트 실패: {str(e)}")

@app.get("/api/human-in-loop/{session_id}/export")
async def export_hil_session(session_id: str, format: str = "coco"):
    """수정된 라벨들을 학습용 형식으로 내보내기"""
    if session_id not in hil_sessions:
        raise HTTPException(status_code=404, detail=f"세션 '{session_id}'를 찾을 수 없습니다.")

    session_info = hil_sessions[session_id]

    # 수정된 라벨들만 수집
    reviewed_labels = []
    for img_info in session_info["images"]:
        if img_info["reviewed"]:
            try:
                with open(img_info["inference_file"], 'r', encoding='utf-8') as f:
                    label_data = json.load(f)
                    reviewed_labels.append(label_data)
            except Exception as e:
                logging.error(f"라벨 데이터 로드 오류: {e}")

    if not reviewed_labels:
        raise HTTPException(status_code=400, detail="수정된 라벨이 없습니다.")

    # 내보내기 파일 생성
    export_dir = Path(session_info["output_dir"]) / "export"
    export_dir.mkdir(exist_ok=True)

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    export_filename = f"human_reviewed_labels_{session_id}_{timestamp}.json"
    export_path = export_dir / export_filename

    export_data = {
        "session_info": {
            "session_id": session_id,
            "model_id": session_info["model_id"],
            "created_at": session_info["created_at"],
            "exported_at": datetime.now().isoformat(),
            "total_reviewed": len(reviewed_labels)
        },
        "labels": reviewed_labels
    }

    with open(export_path, 'w', encoding='utf-8') as f:
        json.dump(export_data, f, ensure_ascii=False, indent=2)

    return {
        "success": True,
        "export_file": str(export_path),
        "reviewed_count": len(reviewed_labels),
        "format": format
    }


@app.get("/api/models/{model_id}/evaluation")
async def get_model_evaluation(model_id: str):
    """특정 모델의 상세 평가 결과를 조회합니다."""
    if model_id not in training_jobs:
        raise HTTPException(status_code=404, detail=f"모델 '{model_id}'를 찾을 수 없습니다.")

    job_info = training_jobs[model_id]
    if job_info['status'] != 'completed':
        raise HTTPException(status_code=400, detail=f"모델 '{model_id}'의 학습이 완료되지 않았습니다.")

    metrics = job_info.get('metrics', {})
    if not metrics:
        raise HTTPException(status_code=404, detail=f"모델 '{model_id}'의 평가 결과를 찾을 수 없습니다.")

    # 메트릭 해석 및 등급 계산
    def get_performance_grade(value):
        if value >= 0.9: return "Excellent"
        elif value >= 0.8: return "Good"
        elif value >= 0.7: return "Fair"
        elif value >= 0.6: return "Poor"
        else: return "Very Poor"


    return JSONResponse(content={
        "model_id": model_id,
        "model_name": job_info['model_name'],
        "evaluation_summary": {
            "overall_performance": get_performance_grade(metrics.get('map50', 0)),
            "detection_accuracy": f"{metrics.get('map50', 0) * 100:.1f}%",
            "precision_score": f"{metrics.get('precision', 0) * 100:.1f}%",
            "recall_score": f"{metrics.get('recall', 0) * 100:.1f}%"
        },
        "detailed_metrics": {
            "map50": {
                "value": metrics.get('map50', 0),
                "percentage": f"{metrics.get('map50', 0) * 100:.1f}%",
                "grade": get_performance_grade(metrics.get('map50', 0)),
                "description": "IoU 0.5에서의 평균 정밀도 (주요 성능 지표)"
            },
            "map50_95": {
                "value": metrics.get('map50_95', 0),
                "percentage": f"{metrics.get('map50_95', 0) * 100:.1f}%",
                "grade": get_performance_grade(metrics.get('map50_95', 0)),
                "description": "IoU 0.5-0.95 범위의 평균 정밀도 (엄격한 평가)"
            },
            "precision": {
                "value": metrics.get('precision', 0),
                "percentage": f"{metrics.get('precision', 0) * 100:.1f}%",
                "grade": get_performance_grade(metrics.get('precision', 0)),
                "description": "정밀도 (예측한 객체 중 실제 객체 비율)"
            },
            "recall": {
                "value": metrics.get('recall', 0),
                "percentage": f"{metrics.get('recall', 0) * 100:.1f}%",
                "grade": get_performance_grade(metrics.get('recall', 0)),
                "description": "재현율 (실제 객체 중 발견한 객체 비율)"
            }
        },
        "training_info": {
            "annotation_files": job_info['annotation_filenames'],
            "training_parameters": {
                "epochs": job_info['epochs'],
                "batch_size": job_info['batch_size'],
                "img_size": job_info['img_size']
            },
            "processed_images": job_info.get('processed_count', 0),
            "training_duration": job_info.get('completed_at') and job_info.get('created_at')
        },
        "created_at": job_info.get('completed_at')
    })

@app.get("/api/evaluation/summary")
async def get_all_models_evaluation_summary():
    """모든 완료된 모델의 평가 결과 요약을 조회합니다."""
    completed_models = []

    for job_id, job_info in training_jobs.items():
        if job_info['status'] == 'completed' and job_info.get('metrics'):
            metrics = job_info['metrics']
            completed_models.append({
                "model_id": job_id,
                "model_name": job_info['model_name'],
                "map50": metrics.get('map50', 0),
                "precision": metrics.get('precision', 0),
                "recall": metrics.get('recall', 0),
                "annotation_files_count": len(job_info.get('annotation_filenames', [])),
                "processed_images": job_info.get('processed_count', 0),
                "completed_at": job_info.get('completed_at'),
                "performance_score": (
                    metrics.get('map50', 0) * 0.5 +
                    metrics.get('precision', 0) * 0.25 +
                    metrics.get('recall', 0) * 0.25
                )  # 종합 성능 점수
            })

    # 성능 순으로 정렬
    completed_models.sort(key=lambda x: x['performance_score'], reverse=True)

    return JSONResponse(content={
        "models": completed_models,
        "total_count": len(completed_models),
        "best_model": completed_models[0] if completed_models else None,
        "average_performance": {
            "map50": sum(m['map50'] for m in completed_models) / len(completed_models) if completed_models else 0,
            "precision": sum(m['precision'] for m in completed_models) / len(completed_models) if completed_models else 0,
            "recall": sum(m['recall'] for m in completed_models) / len(completed_models) if completed_models else 0
        } if completed_models else None
    })

